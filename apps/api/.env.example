PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5432/findit
DATABASE_SSL=false

# Required in production. Generate a long random value.
JWT_SECRET=

# Optional. If absent, /media/analyze uses deterministic mock recognition.
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# Or paste the full Responses URL:
# AZURE_OPENAI_RESPONSES_URL=https://your-resource.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Required if Azure Blob Storage is used for media.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=data

# Required for App Store subscription receipt validation in production.
APPLE_IAP_SHARED_SECRET=
